	partition Calendar = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				CALENDAR(minx(Orders,[Order Date]),MAXX(Orders,[Order date])),
				"Year", YEAR([Date]),
				"MonthNum", MONTH([Date]),
				"Month", FORMAT([Date],"mmm"),
				"YearMonthNum",  FORMAT([Date], "yyyymm"),
				"MonthYear", FORMAT([Date], "mmm-yyyy"),
				"Q", FORMAT([Date], "\Qq"),
				"Q-Sort", QUARTER([Date])*4 + MONTH([Date])
				)

	annotation PBI_Id = d69db1239dc44d4198b093b8d6d5688d

